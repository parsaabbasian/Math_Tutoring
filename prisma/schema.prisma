// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  name            String
  createdAt       DateTime @default(now())
  // Prepaid session balances, credited by Stripe purchases
  onlineCredits   Int      @default(0)
  inPersonCredits Int      @default(0)
  trialUsed       Boolean  @default(false)

  purchases Purchase[]
  bookings  Booking[]
}

model Purchase {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  // Stripe Checkout session id; unique so webhook + return-page fulfillment stays idempotent
  stripeSessionId String   @unique
  productKey      String // trial | online | inPerson
  quantity        Int
  amountTotal     Int // smallest currency unit (cents)
  currency        String
  status          String   @default("completed")
  createdAt       DateTime @default(now())
}

model Booking {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  // Class start, stored as wall-clock Toronto time encoded as UTC
  // (constructed with Date.UTC, displayed with the UTC timezone).
  start     DateTime
  type      String // online | inPerson
  status    String   @default("scheduled") // scheduled | canceled
  createdAt DateTime @default(now())

  @@index([userId, status])
  @@index([start])
}
