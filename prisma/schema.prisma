// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  name            String
  createdAt       DateTime @default(now())
  // Prepaid session balances, credited by Stripe purchases
  onlineCredits   Int      @default(0)
  inPersonCredits Int      @default(0)
  trialUsed       Boolean  @default(false)

  purchases   Purchase[]
  submissions ContactSubmission[]
}

model Purchase {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  // Stripe Checkout session id; unique so webhook + return-page fulfillment stays idempotent
  stripeSessionId String   @unique
  productKey      String // trial | online | inPerson
  quantity        Int
  amountTotal     Int // smallest currency unit (cents)
  currency        String
  status          String   @default("completed")
  createdAt       DateTime @default(now())
}

model ContactSubmission {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  studentName  String
  email        String
  phone        String
  country      String
  gradeLevel   String
  tutoringType String // online | in-person
  address      String?
  postalCode   String?
  language     String   @default("en")
  createdAt    DateTime @default(now())
}
