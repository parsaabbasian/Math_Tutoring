# Copy this file to .env and fill in the values.

# SQLite database file, relative to the project root.
# For production, switch prisma/schema.prisma + the adapter in src/lib/db.ts to Postgres
# (e.g. Neon or Supabase) and put the connection string here instead.
DATABASE_URL="file:./prisma/dev.db"

# Secret used to sign login session cookies (JWT). Generate one with:
#   openssl rand -base64 32
SESSION_SECRET=""

# Stripe keys - use TEST mode keys while developing:
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=""
# Webhook signing secret from `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# or from the webhook endpoint settings in the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=""

# Base URL used for Stripe redirect URLs (production: https://avinmath.com).
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
